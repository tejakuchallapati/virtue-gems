# Gmail SMTP (use an App Password — not your regular Gmail password)
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=virtuegems777@gmail.com
SMTP_PASS=your-gmail-app-password

# Where all notifications are delivered
NOTIFY_EMAIL=virtuegems777@gmail.com
FROM_NAME=Virtue Gems

# Secret key for POST /api/notify (project update emails from the app)
NOTIFY_API_KEY=generate-a-long-random-string

# Public site URL (sitemap, robots, JSON-LD — use your production domain)
NEXT_PUBLIC_SITE_URL=https://virtuegems.com

# Optional: separate API origin if frontend and backend run on different hosts
# NEXT_PUBLIC_API_URL=https://api.virtuegems.com

# WhatsApp-first payments (shown on checkout, WhatsApp bills, admin copy-reply)
NEXT_PUBLIC_UPI_ID=virtuegems@upi
NEXT_PUBLIC_UPI_PAYEE_NAME=Virtue Gems
# NEXT_PUBLIC_BANK_DETAILS=Account: Virtue Gems, HDFC Bank, A/c 1234567890, IFSC HDFC0001234
# NEXT_PUBLIC_COD_ENABLED=false

# WhatsApp (country code + number, no + or spaces)
NEXT_PUBLIC_WHATSAPP_NUMBER=917396178039

# Admin OTP login — only this email can request OTP
ADMIN_EMAIL=virtuegems777@gmail.com

# Secret for signing OTP sessions (any long random string)
OTP_SECRET=generate-a-long-random-string

# SQLite database (optional — defaults to ./data/virtue-gems.db)
# DATABASE_DIR=/var/data/virtue-gems
# DATABASE_PATH=/var/data/virtue-gems/virtue-gems.db
